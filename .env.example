# Заполни три строки ниже — этого достаточно для запуска.

BOT_TOKEN=сюда_токен_от_BotFather
ADMIN_CHAT_ID=сюда_твой_числовой_chat_id
ANTHROPIC_API_KEY=sk-ant-...

# Ниже можно не трогать — это значения по умолчанию.
MODEL=claude-opus-4-8
DIGEST_HOUR=9
DIGEST_MINUTE=0
TIMEZONE=Europe/Moscow
LOOKBACK_HOURS=36
MAX_ITEMS_TO_LLM=60
TOP_N=5

# Молния (режим эксклюзивов): 0 = выключить
FLASH_INTERVAL_HOURS=4
FLASH_LOOKBACK_HOURS=6

# ТОП недели
WEEKLY_DAY=fri
WEEKLY_HOUR=17
WEEKLY_MINUTE=0
WEEKLY_LOOKBACK_HOURS=168

# Подпись лонгридов в Telegra.ph
AUTHOR_NAME=Сергей Нищев
CHANNEL_URL=https://t.me/nishchev

# Вовлечение: добавлять идею опроса к посту
ENGAGEMENT=true

# Месячный дайджест НАШИХ постов (число дня месяца или "last")
MONTHLY_DAY=1
MONTHLY_HOUR=12
MONTHLY_MINUTE=0
MONTHLY_LOOKBACK_DAYS=31

# Доступ к своему каналу (только для месячного дайджеста и петли по статистике).
# Заполни, если нужны эти две функции. Иначе оставь пустыми — остальное работает.
CHANNEL_USERNAME=nishchev
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
USE_STATS_LOOP=true

# Генерация картинок (Nano Banana Pro = Gemini 3 Pro Image)
GEMINI_API_KEY=
IMAGE_MODEL=gemini-3-pro-image-preview
IMAGE_ASPECT=16:9
